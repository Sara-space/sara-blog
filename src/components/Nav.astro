---
const base = import.meta.env.BASE_URL; // p.ej. "/sara-blog/"

const links = [
  { href: "Resumen", label: "Resumen" },
  { href: "publicaciones", label: "Publicaciones" },
  { href: "habilidades", label: "Habilidades" },
  { href: "intereses", label: "Intereses" },
];
---

<nav class="container-balanced py-6 flex items-center justify-between">
  <a href={base} class="font-extrabold tracking-tight text-lg">
    <span class="text-primary" style="color: rgb(var(--primary));">Sara</span>
    <span style="color: rgb(var(--fg) / 0.80);"> · Física</span>
  </a>
  <ul class="hidden md:flex items-center gap-5">
    {links.map(l => <li><a class="nav-link" href={'${base}${l.href}'}>{l.label}</a></li>)}
  </ul>
  <a href={'${base}Resumen'} class="btn btn-primary md:hidden">Menú</a>
</nav>
