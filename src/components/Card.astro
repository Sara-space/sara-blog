---
interface Props {
  title: string;
  href: string;
  description?: string;
}
const { title, href, description = "" } = Astro.props;

const base = import.meta.env.BASE_URL;
// Detecta URL absoluta o anclas/mailto/tel
const isAbs = /^(https?:|mailto:|tel:|#)/.test(href);
// Normaliza: si empieza con "/" añade base; si ya trae base o es relativa, también la anteponemos.
const url = isAbs
  ? href
  : href.startsWith(base)
    ? href
    : href.startsWith("/")
      ? ${base}${href.slice(1)}
      : ${base}${href};

const isExternal = /^https?:\/\//.test(url);
---

<a
  href={url}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noopener noreferrer" : undefined}
  class="card block hover:ring-2 hover:ring-primary/50 transition-shadow"
  style="--tw-ring-color: rgb(var(--primary) / 0.5);"  <!-- fallback si ring-primary/50 no existe -->
>
  <h3 class="text-xl font-semibold mb-2">{title}</h3>
  <p class="text-sm text-muted" style="color: rgb(var(--muted));">{description}</p>
</a>
