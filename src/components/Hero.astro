---
interface Props {
  title: string;
  subtitle?: string;
  ctaHref?: string;
  ctaLabel?: string;
}
const { title, subtitle = "Ingeniería física, semiconductores y divulgación científica.", ctaHref = "Resumen", ctaLabel = "Conóceme" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="container-balanced pt-8 pb-16">
  <div class="grid md:grid-cols-2 gap-8 items-center">
    <div class="space-y-6">
      <h1 class="text-4xl md:text-5xl font-extrabold leading-tight">
        {title}
      </h1>
      <p class="text-lg" style="color: rgb(var(--muted));">{subtitle}</p>
      <div class="flex gap-3">
        <a href={'${base}${ctaHref}'} class="btn btn-primary">{ctaLabel}</a>
        <a href={'${base}blog'} class="btn">Leer el Blog</a>
      </div>
    </div>
    <div class="card">
      <img
        src={'${base}images/sara.png'}
        alt="Sara, ingeniera física — foto profesional"
        class="w-full rounded-xl2 object-cover aspect-[4/3]"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <p class="mt-4 text-sm" style="color: rgb(var(--muted));">Coloca aquí una foto o ilustración profesional.</p>
    </div>
  </div>
</section>
